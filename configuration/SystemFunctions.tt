  <category name="Testing">
    <function export="subscribeTest" name="Subscribe" repeatrate="0">
      <parameter name="Player" type="mcinteger">
<#= playerChoices #>
			</parameter>
      <parameter name="ViewID" type="deviceid" />
    </function>

    <function export="printBuffer" name="PrintBuffer" repeatrate="0">
      <parameter name="Player" type="mcinteger">
<#= playerChoices #>
			</parameter>
      <parameter name="ViewID" type="deviceid" />
    </function>

    <function export="getPlayerStatus" name="Get Player Status" repeatrate="0">
      <parameter name="Player" type="mcinteger">
<#= playerChoices #>
      </parameter>
      <parameter name="ViewID" type="deviceid" />
    </function>

    <function export="browseTest" name="Browse Test" repeatrate="0">
      <parameter name="Player" type="mcinteger">
<#= playerChoices #>
      </parameter>
      <parameter name="Service" type="mcstring">
        <choice name="Favorites" value="favorites" />
        <choice name="MyApps" value="myapps" />
        <choice name="Pandora" value="pandora" />
        <choice name="Shoutcast" value="shoutcast" />
        <choice name="Spotify" value="spotify" />
        <choice name="Radio" value="radios" />
        <choice name="Artists" value="artists" />
        <choice name="Albums" value="albums" />
        <choice name="Genres" value="genres" />
        <choice name="Years" value="years" />
        <choice name="Playlists" value="playlists" />
        <choice name="Home menu" value="home_menu" />
        <choice name="Home" value="home" />
        <choice name="Music Folder" value="bmf" />
        <choice name="New Music" value="new" />
        <choice name="Sirius" value="sirius" />
        <choice name="SKY.fm" value="skyfm" />
        <choice name="Menu" value="menu" />
      </parameter>
      <parameter name="ViewID" type="deviceid" />
    </function>

    <function export="browseSubMenuTest" name="Sub Browse Test" repeatrate="0">
      <parameter name="Player" type="mcinteger">
<#= playerChoices #>
      </parameter>
      <parameter name="Service" type="mcstring">
        <choice name="Pandora" value="pandora" />
        <choice name="Shoutcast" value="shoutcast" />
        <choice name="Spotify" value="spotify" />
        <choice name="Sirius" value="sirius" />
        <choice name="SKY.fm" value="skyfm" />
      </parameter>
      <parameter name="ViewID" type="deviceid" />
    </function>

  </category>
</functions>
