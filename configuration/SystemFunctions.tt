  <category name="Player Sync">
    <function export="syncListSelection" name="Select From Sync List" repeatrate="0">
        <parameter name="Player" type="mcinteger">
<#= playerChoices #>
      </parameter>
      <parameter description="list index" max="999999" min="0" name="index" type="integer" />
      <parameter default="Toggle" name="Sync or Unsync" type="mcstring">
        <choice name="Sync" value="Sync" />
        <choice name="Unsync" value="Sync" />
        <choice name="Toggle" value="Toggle" />
        <choice name="Preset Variable" value="Variable" /> 
      </parameter>
      <parameter name="ViewID" type="deviceid" />
    </function>

    <function export="setSyncType" name="Set Sync Type" repeatrate="0">
