<#@ output extension=".xml" #>
<#@ include file="Variables.t4" #>
<#
string playerChoices = "";
for (var i = 1; i <= playerCount; i++)
{
  var paddedIndex = i.ToString().PadLeft(2, '0');
	playerChoices += $"        <choice name=\"%%NameP{ paddedIndex }%%\" value=\"{i}\" sourceid=\"Player{i}\" condition=\"$Total_Players > {i - 1}\" />";
  if (i < playerCount) { playerChoices += Environment.NewLine; }
}
#>
<?xml version='1.0' encoding='utf-8'?>
<functions>
  <category name="Pop Up Vars">
    <function export="showHideSyncPopup" name="Set Show Popup Sync Var" repeatrate="0">
      <parameter name="Player" type="mcinteger">
<#= playerChoices #>
			</parameter>
      <parameter default="Toggle" name="What To Do" type="mcstring">
        <choice name="Set to True" value="true" />
        <choice name="Set to False" value="false" />
        <choice name="Toggle" value="Toggle" />
      </parameter>
      <parameter name="ViewID" type="deviceid" />
    </function>
  </category>

  <category name="Controls">
    <function alias="transport" export="transport:Pause" name="Pause" repeatrate="0" buttontag="Pause">
      <parameter name="Player" type="mcinteger">
<#= playerChoices #>
			</parameter>
      <parameter default="pause" name="Control" type="string" />
      <parameter name="ViewID" type="deviceid" />
    </function>

    <function alias="transport" export="transport:Play" name="Play" repeatrate="0" buttontag="Play">
